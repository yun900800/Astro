{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/notes/rss\\.xml/?$",
			"dest": "_render"
		},
		{
			"src": "^/oauth/callback$",
			"dest": "_render"
		},
		{
			"src": "^/oauth$",
			"dest": "_render"
		},
		{
			"src": "^/rss\\.xml/?$",
			"dest": "_render"
		},
		{
			"src": "^/sitemap\\.xml/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "/404.html",
			"status": 404
		}
	]
}